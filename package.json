{
  "name": "msca",
  "version": "0.1.0",
  "description": "MSCA - 多设备移动端投屏控制系统",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "dev:backend": "uv run --project backend python backend/__main__.py",
    "build": "npm --prefix frontend run build",
    "build:web": "node scripts/build-web.mjs",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && npm run backend:build && electron-builder",
    "backend:build": "node scripts/build-backend.mjs",
    "backend:verify": "node scripts/verify-backend.mjs",
    "dist:clean": "node scripts/clean-dist.mjs",
    "lint": "npm --prefix frontend run lint",
    "format": "npm --prefix frontend run format"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.msca.app",
    "productName": "MSCA",
    "directories": {
      "output": "dist/electron"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/"
      },
      {
        "from": "bin/android/",
        "to": "bin/android/"
      },
      {
        "from": "bin/ios/",
        "to": "bin/ios/"
      }
    ],
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    }
  }
}
